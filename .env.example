# ==================== LLM 提供商配置 ====================
# 选择使用的 LLM 提供商：openai / hunyuan / qwen
LLM_PROVIDER=hunyuan

# OpenAI API 配置（当 LLM_PROVIDER=openai 时使用）
OPENAI_API_KEY=your-openai-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# 混元 API 配置（当 LLM_PROVIDER=hunyuan 时使用）
HUNYUAN_API_KEY=your-hunyuan-key-here

# 阿里云通义千问 API 配置（当 LLM_PROVIDER=qwen 时使用）
QWEN_API_KEY=sk-your-dashscope-key-here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 模型配置 ====================
# 对话模型（根据提供商自动选择，修改 LLM_PROVIDER 后同步修改此项）
# OpenAI:  gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# 混元:    hunyuan-turbo, hunyuan-lite, hunyuan-pro, hunyuan-turbos-latest
# Qwen:    qwen-plus, qwen-turbo, qwen-max, qwen-long, qwen3-235b-a22b
LLM_MODEL=hunyuan-turbo

# Embedding 模型（根据提供商自动选择，修改 LLM_PROVIDER 后同步修改此项）
# OpenAI:  text-embedding-3-small (1536维), text-embedding-3-large (3072维)
# 混元:    hunyuan-embedding (1024维，固定)
# Qwen:    qwen3-vl-embedding
EMBEDDING_MODEL=hunyuan-embedding
EMBEDDING_DIMENSION=1024

# ==================== 向量检索配置 ====================
FAISS_INDEX_PATH=./data/indexes/faiss_index
TOP_K=5

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password

# 其余配置

# Langfuse 配置（可选）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# 服务端口
AI_ENGINE_PORT=8000
GO_GATEWAY_PORT=8080

# MCP
MCP_LOG_SERVER_URL=